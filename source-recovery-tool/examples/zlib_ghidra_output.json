                "raw_c": "ulong adler32(ulong adler, byte *buf, uint len)\n{\n  ulong s1;\n  ulong s2;\n  uint k;\n  \n  if (buf == (byte *)0x0) {\n    return 1;\n  }\n  s1 = adler & 0xffff;\n  s2 = (adler >> 0x10) & 0xffff;\n  while (len != 0) {\n    if (len < 0x15b0) {\n      k = len;\n    }\n    else {\n      k = 0x15b0;\n    }\n    len = len - k;\n    while (k >= 0x10) {\n      s1 = s1 + (ulong)*buf;\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[1];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[2];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[3];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[4];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[5];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[6];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[7];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[8];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[9];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[10];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[11];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[12];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[13];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[14];\n      s2 = s2 + s1;\n      s1 = s1 + (ulong)buf[15];\n      s2 = s2 + s1;\n      buf = buf + 0x10;\n      k = k - 0x10;\n    }\n    while (k != 0) {\n      s1 = s1 + (ulong)*buf;\n      s2 = s2 + s1;\n      buf = buf + 1;\n      k = k - 1;\n    }\n    s1 = s1 % 0xfff1;\n    s2 = s2 % 0xfff1;\n  }\n  return s2 << 0x10 | s1;\n}",
